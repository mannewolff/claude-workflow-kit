{
  "codeHost": "github",
  "issueTracker": "github",
  "buildChecks": [
    "mvn verify"
  ],
  "mutationCommand": "mvn org.pitest:pitest-maven:mutationCoverage",
  "mainBranch": "main",
  "productionBranch": "production",
  "reviewScope": "diff",
  "reviewModel": "claude-opus-4-8",
  "triggers": {
    "go": "GO",
    "push": "push main",
    "merge": "merge production"
  },
  "local": {
    "issuesDir": "issues"
  },
  "columns": {
    "backlog": "Backlog",
    "ready": "Ready",
    "in_progress": "In Progress",
    "in_review": "In Review",
    "done": "Done"
  },
  "github": {
    "projectNumber": 1
  }
}
