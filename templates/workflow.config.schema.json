{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stellwerk workflow.config",
  "description": "Projekt-spezifische Konfiguration fuer die Stellwerk-Skill-Bibliothek",
  "type": "object",
  "properties": {
    "buildChecks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Kommandos, die /local-check sequenziell ausfuehrt (Build, Tests). Leer-Array = keine automatisierten Checks.",
      "default": []
    },
    "mutationCommand": {
      "type": "string",
      "description": "Kommando fuer Mutations-Tests (optional). Leer-String oder fehlendes Feld = kein Mutations-Test.",
      "default": ""
    },
    "mainBranch": {
      "type": "string",
      "minLength": 1,
      "description": "Branch fuer lokale Commits und Push (Schritt 8).",
      "default": "main"
    },
    "productionBranch": {
      "type": "string",
      "minLength": 1,
      "description": "Ziel-Branch fuer den PR in Schritt 9 (merge production).",
      "default": "production"
    },
    "reviewScope": {
      "type": "string",
      "enum": ["diff", "full"],
      "description": "Umfang des Review-Materials: 'diff' = git diff seit letztem Push; 'full' = gesamter Quelltext.",
      "default": "diff"
    },
    "reviewModel": {
      "type": "string",
      "minLength": 1,
      "description": "Modell-ID fuer den Reviewer-Subagent (Opus-Pin). Muss ein gueltiger Claude-Modell-Identifier sein.",
      "default": "claude-opus-4-8"
    },
    "triggers": {
      "type": "object",
      "description": "Trigger-Phrasen fuer die drei menschlichen Stop-Punkte.",
      "properties": {
        "go": {
          "type": "string",
          "minLength": 1,
          "description": "Phrase fuer das GO zur Implementierung.",
          "default": "GO"
        },
        "push": {
          "type": "string",
          "minLength": 1,
          "description": "Phrase fuer Push auf mainBranch (Schritt 8).",
          "default": "push main"
        },
        "merge": {
          "type": "string",
          "minLength": 1,
          "description": "Phrase fuer PR nach productionBranch (Schritt 9).",
          "default": "merge production"
        }
      },
      "required": [],
      "additionalProperties": false,
      "default": {
        "go": "GO",
        "push": "push main",
        "merge": "merge production"
      }
    }
  },
  "required": [],
  "additionalProperties": false,
  "defaults": {
    "buildChecks": [],
    "mutationCommand": "",
    "mainBranch": "main",
    "productionBranch": "production",
    "reviewScope": "diff",
    "reviewModel": "claude-opus-4-8",
    "triggers": {
      "go": "GO",
      "push": "push main",
      "merge": "merge production"
    }
  },
  "validationRules": [
    {
      "field": "reviewScope",
      "rule": "enum",
      "allowed": ["diff", "full"],
      "error": "reviewScope muss 'diff' oder 'full' sein."
    },
    {
      "field": "reviewModel",
      "rule": "pattern",
      "pattern": "^claude-",
      "error": "reviewModel muss eine Claude-Modell-ID sein (z.B. 'claude-opus-4-8')."
    }
  ]
}
